\f2\b0\fs26 \cf0 sequenceDiagram\
    participant Dev as Developer\
    participant GH as GitHub\
    participant CI as CI Runner\
    participant CD as CD Runner\
    participant ECR as Amazon ECR\
    participant AR as App Runner\
    participant S3 as S3 + CloudFront\
\
    Dev->>GH: git push origin main\
    GH->>CI: Trigger ci.yml (push event)\
\
    CI->>CI: setup-python-env (composite action)\
    CI->>CI: pytest tests/  JUnit XML + log\
    CI->>CI: setup-node-env (composite action)\
    CI->>CI: npm test  Jest JSON + log\
    CI->>CI: docker build  health check\
    CI->>GH: Upload artifacts (30-day retention)\
    CI->>GH: CI passed \
\
    GH->>CD: Trigger cd.yml (workflow_run: completed)\
    CD->>CD: Gate: verify CI conclusion == 'success'\
    CD->>CD: configure-aws-credentials\
    CD->>CD: amazon-ecr-login\
    CD->>CD: docker build --tag :sha + :latest\
    CD->>ECR: docker push :sha (revision tag)\
    CD->>ECR: docker push :latest (convenience tag)\
    CD->>AR: aws apprunner start-deployment\
    AR->>AR: Pull :latest from ECR, replace revision\
    CD->>CD: npm run build (REACT_APP_API_URL injected)\
    CD->>S3: aws s3 sync build/ (cache headers)\
    CD->>S3: create-invalidation (CloudFront)\
    CD->>GH: Upload deployment record (365-day retention)\
